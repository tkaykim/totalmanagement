# Play 스토어 출시용 업로드 키 (release 서명)
# https://developer.android.com/studio/publish/app-signing?hl=ko#generate-key
#
# 1. 이 파일을 keystore.properties 로 복사한 뒤 아래 값을 실제 값으로 채우세요.
# 2. 키스토어가 없으면: android 폴더에서 .\setup-release-keystore.ps1 실행
#
# storeFile: app 모듈(android/app) 기준 상대 경로
storeFile=totalmanagements-upload-key.jks
storePassword=여기에_키스토어_비밀번호
keyAlias=totalmanagements-upload
keyPassword=여기에_키_비밀번호
